rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Función de admin robusta que evita recursión infinita en consultas de grupo
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'admin';
    }

    // --- BYPASS GLOBAL PARA ADMIN ---
    // Permite al administrador leer y escribir en CUALQUIER colección o subcolección
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // --- REGLAS DE USUARIO ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /orders/{orderId} {
        allow read, create: if isOwner(userId);
        allow update: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
      }
    }

    match /businesses/{businessId} {
      allow get, create, update, delete: if isOwner(businessId);
    }

    match /products/{productId} {
      allow read: if true;
    }

    // --- SOPORTE PARA COLLECTION GROUPS ---
    // Específicamente para que isAdmin() pueda listar todos los pedidos y notificaciones
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
    match /{path=**}/notifications/{notificationId} {
      allow list: if isAdmin();
    }
  }
}
